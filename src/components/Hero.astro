---
const base = import.meta.env.BASE_URL;
---

<section class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-3xl mx-auto text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl">
      Scientific Agentic Engineering
    </h1>
    <p class="mt-6 text-lg text-gray-600 leading-relaxed">
      A methodology for integrating AI agents into scientific software workflows —
      principled, incremental, and grounded in real practice.
    </p>
    <div class="mt-8">
      <a
        href={`${base}framework/`}
        class="inline-block rounded-md bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors"
      >
        Read the Framework
      </a>
    </div>
  </div>
</section>
