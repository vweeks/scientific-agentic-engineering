---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('framework'))
  .filter(entry => !entry.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Framework — Scientific Agentic Engineering" description="Principles and patterns for responsible AI-agent integration in scientific software.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-gray-900">Framework</h1>
    <p class="mt-4 text-gray-600 leading-relaxed">
      Principles and patterns for responsible AI-agent integration in scientific software development.
    </p>

    {entries.length > 0 ? (
      <ul class="mt-8 space-y-4">
        {entries.map(entry => (
          <li>
            <a href={`${import.meta.env.BASE_URL}framework/${entry.id}/`} class="group block rounded-lg border border-gray-200 p-4 hover:border-blue-300 transition-colors">
              <h2 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600">{entry.data.title}</h2>
              <p class="mt-1 text-sm text-gray-500">{entry.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-8 text-gray-400 italic">
        Framework content is under development as part of Milestone 1 (July 2026).
      </p>
    )}
  </div>
</BaseLayout>
